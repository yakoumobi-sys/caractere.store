# Supabase — récupère ces valeurs sur supabase.com > ton projet > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
SUPABASE_SERVICE_ROLE_KEY=eyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Resend — récupère ta clé sur resend.com > API Keys
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Email qui reçoit les notifications de commandes
ADMIN_EMAIL=ton@email.com

# Mot de passe admin (pour te connecter à /admin)
ADMIN_PASSWORD=motdepassesecret123

# Secret pour les sessions (génère une chaîne aléatoire longue)
NEXTAUTH_SECRET=une_chaine_aleatoire_tres_longue_ici
